# ── Backend (apenas servidor; NUNCA prefixe com VITE_) ──────────────
# Banco Turso único (autenticação + dados do app)
DB_URL=libsql://macronaut-suaorg.turso.io
DB_TOKEN=token-full-access-do-banco

# URL entregue ao cliente no login, caso difira da DB_URL (opcional)
# DB_URL_PUBLIC=libsql://macronaut-suaorg.turso.io

# Caminho do JSON da TACO para o seed inicial (opcional; default data/taco.sample.json)
# TACO_JSON=data/taco.sample.json

# ── AI Gateway (server-only; roda na máquina da ALOY) ──────────────────
# DB_URL / DB_TOKEN já definidos acima são reusados pelo gateway.
ALOY_URL=http://127.0.0.1:8080
ALOY_MACRONAUT_APP_TOKEN=token-app-macronaut-na-aloy
GEMINI_MODEL=gemini-flash-latest
PORT=8787

# ── Cliente (público, vai no bundle) ──────────────────
# URL do AI Gateway (na rede/Tailnet) que o navegador chama pra IA.
VITE_AI_GATEWAY_URL=http://127.0.0.1:8787
