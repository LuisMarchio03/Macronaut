# ── Backend (apenas servidor; NUNCA prefixe com VITE_) ─────────────
# Banco de autenticação compartilhado (tabela users)
AUTH_DB_URL=libsql://macronaut-auth-suaorg.turso.io
AUTH_DB_TOKEN=token-do-auth-db

# Turso Platform API — criar banco no provisionamento e emitir token no login
TURSO_ORG=sua-org-slug
TURSO_PLATFORM_TOKEN=seu-platform-token
TURSO_GROUP=default

# Validade (em dias) do token emitido no login (opcional; default 7)
TOKEN_TTL_DAYS=7
